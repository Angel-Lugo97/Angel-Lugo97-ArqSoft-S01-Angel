@model Catalogo.Models.Item

@{
    ViewData["Title"] = "Agregar videojuego";
}

<div class="form-panel">
    <span class="hero-badge">NUEVO REGISTRO</span>

    <h1 class="page-title">Agregar Videojuego</h1>

    <p class="lead">
        Registra un nuevo videojuego en el catálogo de la forja.
        Completa los datos para añadirlo a la colección.
    </p>

    <hr class="forge-divider" />

    <form asp-controller="Catalogo" asp-action="Agregar" method="post">
        <div class="mb-3">
            <label asp-for="Titulo" class="form-label">Título</label>
            <input asp-for="Titulo" class="form-control" placeholder="Ejemplo: Halo Infinite" />
            <span asp-validation-for="Titulo" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Genero" class="form-label">Género</label>
            <input asp-for="Genero" class="form-control" placeholder="Ejemplo: Acción, RPG, Aventura" />
            <span asp-validation-for="Genero" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Ano" class="form-label">Año</label>
            <input asp-for="Ano" class="form-control" placeholder="Ejemplo: 2024" />
            <span asp-validation-for="Ano" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Consola" class="form-label">Consola</label>
            <input asp-for="Consola" class="form-control" placeholder="Ejemplo: Xbox, PlayStation, PC, Nintendo Switch" />
            <span asp-validation-for="Consola" class="text-danger"></span>
        </div>

        <div class="mb-4">
            <label asp-for="Descripcion" class="form-label">Descripción</label>
            <textarea asp-for="Descripcion" class="form-control" rows="5" placeholder="Escribe una pequeña descripción del videojuego"></textarea>
            <span asp-validation-for="Descripcion" class="text-danger"></span>
        </div>

        <div class="d-flex flex-wrap gap-2">
            <button type="submit" class="btn btn-primary animate-pulse">
                Guardar videojuego
            </button>

            <a asp-controller="Catalogo" asp-action="Index" class="btn btn-outline-light custom-outline">
                Cancelar
            </a>
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}